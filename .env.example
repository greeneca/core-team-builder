# Copy this file to .env and adjust values for your environment.
# NEVER commit the real .env file (it is git-ignored).

# --- PostgreSQL ---
POSTGRES_USER=ctb
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=core_team_builder

# --- Backend ---
# JWT_SECRET MUST be a long, random string in any non-local environment.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_TTL=24h
# Origin allowed for browser API requests. With the nginx proxy this is the
# frontend URL; requests are same-origin so CORS is rarely triggered.
CORS_ORIGIN=http://localhost:8081

# --- Frontend ---
FRONTEND_PORT=8081

# --- Seed (test user created by the seed job) ---
SEED_USERNAME=testuser
SEED_EMAIL=test@example.com
SEED_PASSWORD=changeme123
