# Copy this file to .env and adjust values for your environment.
# NEVER commit the real .env file (it is git-ignored).

# --- PostgreSQL ---
POSTGRES_USER=ctb
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=core_team_builder

# --- Backend ---
# JWT_SECRET MUST be a long, random string (>= 32 bytes; the server refuses to
# start otherwise). Generate one with:  openssl rand -base64 48
JWT_SECRET=dev-only-insecure-secret-change-me-32-bytes-min
# JWT_TTL is the SHORT-lived access-token lifetime (default 15m). Clients use the
# refresh token to obtain new access tokens without re-logging in.
JWT_TTL=15m
# REFRESH_TTL is the long-lived refresh-token lifetime (default 720h = 30 days).
REFRESH_TTL=720h
# Origin allowed for browser API requests. With the nginx proxy this is the
# frontend URL; requests are same-origin so CORS is rarely triggered.
CORS_ORIGIN=http://localhost:8081

# --- Password reset / email ---
# APP_BASE_URL is the public base URL of the site, used to build the link in the
# password-reset email (e.g. https://teams.example.com). Defaults to CORS_ORIGIN.
APP_BASE_URL=http://localhost:8081
# How long a password-reset link stays valid (default 1h). Keep it short.
PASSWORD_RESET_TTL=1h
# SMTP relay for outbound mail. When SMTP_HOST is empty, reset emails are written
# to the backend log instead of sent (handy for local dev — copy the link from
# the logs). Port 465 uses implicit TLS; other ports (e.g. 587) use STARTTLS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# Envelope/header From address. Use a display name + address, e.g.
# "Core Team Builder <noreply@example.com>".
SMTP_FROM=Core Team Builder <noreply@example.com>

# --- Discord bot (optional) ---
# Only needed to run the bot service:  docker compose --profile bot up
# Create an application + bot at https://discord.com/developers/applications,
# copy the bot token here, and invite the bot with the applications.commands and
# bot scopes. The bot opens an outbound connection to Discord (no inbound port).
DISCORD_BOT_TOKEN=
# Application (client) ID from the Discord developer portal. Optional: the bot
# falls back to its own user ID when registering commands.
DISCORD_APP_ID=
# If set, slash commands register to this single guild for instant availability
# (recommended during development). Leave empty to register globally (the first
# global registration can take up to ~1h to appear).
DISCORD_GUILD_ID=

# --- Sign in with Discord (OAuth2, optional) ---
# Enables a "Continue with Discord" button on the login page. Signing up this way
# stores the user's Discord ID on their account, so they can use the bot's
# /coreteam commands WITHOUT running /coreteam link. Leave CLIENT_ID/SECRET empty
# to hide the button. These are used by the API server (not the bot).
# From the Discord developer portal: OAuth2 → Client ID / Client Secret. Also add
# the redirect URL below to OAuth2 → Redirects, and request the "identify" and
# "email" scopes.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Absolute, public callback URL. Must match a redirect registered in the portal
# exactly. Defaults to APP_BASE_URL + /api/auth/discord/callback when unset.
DISCORD_OAUTH_REDIRECT_URL=http://localhost:8081/api/auth/discord/callback

# --- Frontend ---
FRONTEND_PORT=8081

# --- Seed (test user created by the seed job) ---
SEED_USERNAME=testuser
SEED_EMAIL=test@example.com
# Must be at least 12 characters (enforced by the password policy). Change this.
SEED_PASSWORD=change-me-please

# --- Database backup / restore (optional, on-demand profiles) ---
# Create a dump under ./backups:
#   docker compose --profile backup run --rm backup
# Restore a dump: set RESTORE_FILE to a filename under ./backups, then:
#   docker compose --profile restore run --rm restore
# Leave empty unless you are restoring.
RESTORE_FILE=
